# ============================================================
#  Configuration du pipeline — copier en .env et compléter
#  ⚠️ Ne committez JAMAIS le fichier .env (il contient vos clés)
# ============================================================

# 🎬 SOURCE VIDÉO
YOUTUBE_URL=https://www.youtube.com/watch?v=VOTRE_VIDEO_ID

# 🔊 AUDIO
AUDIO_FORMAT=mp3          # mp3 | wav | m4a | opus
AUDIO_QUALITY=192         # kbps (128, 192, 320)

# 🎙️ TRANSCRIPTION (Whisper)
# tiny | base | small | medium | large
# Arabe : medium minimum recommandé
WHISPER_MODEL=medium
SOURCE_LANGUAGE=ar        # Code ISO 639-1 (ar, fr, en, ...)
OUTPUT_FORMAT=txt         # txt | srt | vtt | json

# 🌍 TRADUCTION
TARGET_LANG=fr

# Moteur : claude | deepl | libretranslate
TRANSLATE_ENGINE=deepl

# Claude / Anthropic (si TRANSLATE_ENGINE=claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# DeepL (si TRANSLATE_ENGINE=deepl) — https://www.deepl.com/pro-api
DEEPL_API_KEY=

# ⚙️ LIBRETRANSLATE (si TRANSLATE_ENGINE=libretranslate)
LIBRETRANSLATE_URL=http://libretranslate:5000
LIBRETRANSLATE_PORT=5000
LT_LOAD_ONLY=ar,fr,en
LT_THREADS=4
